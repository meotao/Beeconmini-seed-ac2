# =============================================================================
# MT7981 平台通用配置 (ImmortalWrt 24.10.1)
# 适用于: BeeconMini SEED AC2 (filogic 平台, 无 Wi-Fi)
# =============================================================================

# ===== 目标平台 =====
# 注意: subtarget 是 filogic 而非 mt7981 (源码 target/linux/mediatek/Makefile 确认)
CONFIG_TARGET_mediatek=y
CONFIG_TARGET_mediatek_filogic=y

# ===== 镜像格式 =====
CONFIG_TARGET_ROOTFS_SQUASHFS=y
# CONFIG_TARGET_ROOTFS_INITRAMFS is not set

# ===== dnsmasq 冲突修复 =====
# dnsmasq 与 dnsmasq-full 冲突 (提供同一二进制)
# OpenClash 等依赖 dnsmasq-full (含 DNSSEC、ipset)
# 必须禁用基础版
# CONFIG_PACKAGE_dnsmasq is not set
CONFIG_PACKAGE_dnsmasq-full=y

# ===== LuCI 基础 =====
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-compat=y
CONFIG_PACKAGE_luci-base=y
CONFIG_PACKAGE_luci-mod-admin-full=y
CONFIG_PACKAGE_luci-lib-ipkg=y
CONFIG_LUCI_LANG_zh_Hans=y
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y
CONFIG_PACKAGE_luci-theme-bootstrap=y
CONFIG_PACKAGE_luci-theme-argon=y
CONFIG_PACKAGE_luci-app-argon-config=y
CONFIG_PACKAGE_luci-i18n-argon-config-zh-cn=y

# ===== 常用 LuCI 应用 =====
CONFIG_PACKAGE_luci-app-firewall=y
CONFIG_PACKAGE_luci-i18n-firewall-zh-cn=y
CONFIG_PACKAGE_luci-app-opkg=y
CONFIG_PACKAGE_luci-app-upnp=y
CONFIG_PACKAGE_luci-i18n-upnp-zh-cn=y
CONFIG_PACKAGE_luci-app-ttyd=y
CONFIG_PACKAGE_luci-i18n-ttyd-zh-cn=y

# ===== TurboACC 网络加速 =====
# 功能: 软件流量分载 + Fullcone NAT + BBR + SFE(可选)
# 依赖: add_turboacc.sh 替换 firewall4/nftables/libnftnl 并打 patch 952/953/613
CONFIG_PACKAGE_luci-app-turboacc=y
CONFIG_PACKAGE_luci-app-turboacc_INCLUDE_OFFLOADING=y
CONFIG_PACKAGE_luci-app-turboacc_INCLUDE_BBR_CCA=y
CONFIG_PACKAGE_luci-app-turboacc_INCLUDE_NFT_FULLCONE=y
CONFIG_PACKAGE_kmod-nft-offload=y
CONFIG_PACKAGE_kmod-tcp-bbr=y
# kmod-nft-fullcone 有 Kconfig 自引用 bug，必须显式声明
CONFIG_PACKAGE_kmod-nft-fullcone=y

# ===== SFE (Shortcut Forwarding Engine) =====
# patch 953 向 skbuff.h 注入 fast_forwarded 字段 (受 #ifdef CONFIG_SHORTCUT_FE 保护)
# 必须在 config-6.6 中设置 CONFIG_SHORTCUT_FE=y (add_turboacc.sh 默认写的是 "is not set")
CONFIG_PACKAGE_kmod-shortcut-fe=y
CONFIG_PACKAGE_kmod-shortcut-fe-cm=y
CONFIG_PACKAGE_kmod-fast-classifier=y

# ===== 网络基础 =====
CONFIG_PACKAGE_kmod-nft-core=y
CONFIG_PACKAGE_kmod-nft-nat=y
CONFIG_PACKAGE_kmod-nft-fib=y
CONFIG_PACKAGE_kmod-tun=y
CONFIG_PACKAGE_iptables-nft=y
CONFIG_PACKAGE_ip6tables-nft=y

# ===== DSA 网络架构 =====
# filogic 平台使用 DSA (不用 swconfig)
CONFIG_PACKAGE_kmod-net-dsa=y

# ===== 存储支持 =====
CONFIG_PACKAGE_kmod-fs-f2fs=y
CONFIG_PACKAGE_kmod-fs-ext4=y
CONFIG_PACKAGE_mkf2fs=y
CONFIG_PACKAGE_e2fsprogs=y
CONFIG_PACKAGE_block-mount=y

# ===== USB =====
CONFIG_PACKAGE_kmod-usb-core=y
CONFIG_PACKAGE_kmod-usb3=y
CONFIG_PACKAGE_kmod-usb-storage=y

# ===== 基础工具 =====
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_wget-ssl=y
CONFIG_PACKAGE_nano=y
CONFIG_PACKAGE_ip-full=y

# ===== 禁用不需要的库 =====
# libfido2 → libpam → libxcrypt 依赖链会导致编译失败
# CONFIG_PACKAGE_libfido2 is not set
# CONFIG_PACKAGE_libcbor is not set
# CONFIG_PACKAGE_libevdev is not set
