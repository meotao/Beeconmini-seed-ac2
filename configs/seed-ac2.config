# =============================================================
# configs/seed-ac2.config
# BeeconMini SEED AC2 设备专属差异配置
#
# 硬件规格（来自 DTS mt7981b-beeconmini-seed-ac2.dts 分析）：
#   CPU     : MT7981B (Filogic 820, ARM Cortex-A53 ×2)
#   Switch  : RTL8373（8×2.5G，通过 MDIO 总线连接，驱动 kmod-switch-rtl8373）
#   PoE控制 : RTL8238B（通过 I2C-GPIO, SCL=GPIO46 / SDA=GPIO47）
#   WAN PHY : RTL8221B（2.5G PHY，MDIO addr=7，接 gmac1/eth1）
#   LAN     : gmac0/eth0 → RTL8373 → 8×RJ45 PoE+，单口最大 30W
#   存储    : 1G RAM + 64G eMMC（bus-width=8，升级方式 emmc_do_upgrade）
#   Wi-Fi   : 无
#   subtarget: mediatek/filogic（filogic.mk 确认）
#
# 用法：
#   cat configs/mt7981-common.config configs/seed-ac2.config > .config
#   make defconfig
# =============================================================

# ------------------------------------------------------------
# 目标平台 & 设备型号（subtarget = filogic，非 mt7981）
# CONFIG_TARGET_mediatek_filogic_DEVICE_beeconmini_seed-ac2 来自 filogic.mk
# ------------------------------------------------------------
CONFIG_TARGET_MULTI_PROFILE=n
CONFIG_TARGET_ALL_PROFILES=n
CONFIG_TARGET_mediatek=y
CONFIG_TARGET_mediatek_filogic=y
CONFIG_TARGET_mediatek_filogic_DEVICE_beeconmini_seed-ac2=y

# ------------------------------------------------------------
# RTL8373 交换芯片驱动（SEED AC2 专用）
# 来源：package/kernel/rtl8373/Makefile（PKG_NAME:=switch-rtl8373）
# DEPENDS:=+kmod-i2c-gpio（RTL8373 通过 I2C-GPIO 桥接到 RTL8238B PoE 控制器）
# rtl8373n (PKG_NAME:=switch-rtl8373n) 是 SEED AC3 专用，本设备不使用
# ------------------------------------------------------------
CONFIG_PACKAGE_kmod-i2c-gpio=y
CONFIG_PACKAGE_kmod-switch-rtl8373=y
# CONFIG_PACKAGE_kmod-switch-rtl8373n is not set

# ------------------------------------------------------------
# PoE 管理（RTL8238B 控制 8 口 PoE+，单口最大 30W）
# ------------------------------------------------------------
CONFIG_PACKAGE_kmod-poe=y
CONFIG_PACKAGE_poe-cli=y
CONFIG_PACKAGE_luci-app-poe=y

# ------------------------------------------------------------
# OpenClash（透明代理）
# 依赖 kmod-tun 已在 common 中声明
#
# 注意：luci-app-openclash 在 immortalwrt 24.10.1 中会自动拉入
# shadowsocks-rust，后者需要从 Rust CI 下载预编译 LLVM，
# 但该 URL 已 404 失效，导致编译失败。
# 因此必须在此明确禁用 shadowsocks-rust 和 rust 工具链。
# ------------------------------------------------------------
CONFIG_PACKAGE_luci-app-openclash=y
# CONFIG_PACKAGE_shadowsocks-rust is not set
# CONFIG_PACKAGE_shadowsocks-rust-sslocal is not set
# CONFIG_PACKAGE_shadowsocks-rust-ssserver is not set
# CONFIG_PACKAGE_rust is not set
# CONFIG_PACKAGE_python-setuptools-rust is not set

# ------------------------------------------------------------
# OpenAppFilter / OAF（应用过滤 / 防沉迷）
# 来源：package/OpenAppFilter（workflow 中 git clone 到 package/ 目录）
#
# 注意：OpenAppFilter 的 Kconfig 存在自引用循环依赖 bug：
#   "PACKAGE_kmod-oaf is selected by PACKAGE_kmod-oaf"
# 导致 make defconfig 跳过 kmod-oaf，kmod-oaf.ipk 不会被打包，
# 进而 luci-app-oaf / appfilter 因找不到依赖而安装失败。
#
# 修复：显式声明全部三个子包为 =y，强制构建系统选中，绕过 Kconfig bug。
#   kmod-oaf    — 内核 netfilter 模块（必须显式声明，否则被跳过）
#   appfilter   — 用户态服务守护进程（oaf/ 子目录编译产物的实际包名）
#   luci-app-oaf — LuCI 管理页面
# ------------------------------------------------------------
CONFIG_PACKAGE_kmod-oaf=y
CONFIG_PACKAGE_appfilter=y
CONFIG_PACKAGE_luci-app-oaf=y
CONFIG_PACKAGE_luci-i18n-oaf-zh-cn=y

# ------------------------------------------------------------
# NLBW（Netlink 实时带宽监控）
# ------------------------------------------------------------
CONFIG_PACKAGE_nlbw=y
CONFIG_PACKAGE_luci-app-nlbw=y
CONFIG_PACKAGE_luci-i18n-nlbw-zh-cn=y

# ------------------------------------------------------------
# VLMCSD（KMS 激活服务器）
# ------------------------------------------------------------
CONFIG_PACKAGE_vlmcsd=y
CONFIG_PACKAGE_luci-app-vlmcsd=y
CONFIG_PACKAGE_luci-i18n-vlmcsd-zh-cn=y

# ------------------------------------------------------------
# ttyd（Web 终端）
# ------------------------------------------------------------
CONFIG_PACKAGE_ttyd=y
CONFIG_PACKAGE_luci-app-ttyd=y
CONFIG_PACKAGE_luci-i18n-ttyd-zh-cn=y

# ------------------------------------------------------------
# iStore（应用商店）
# 来源：iStore feed（workflow 中已添加 feeds.conf 条目）
# ------------------------------------------------------------
CONFIG_PACKAGE_luci-app-store=y

# ------------------------------------------------------------
# QuickStart（快速配置向导）
# 来源：lq-wq/luci-app-quickstart（workflow 中 git clone 到 package/）
#   后端: linkease/nas-packages → package/quickstart
#   前端: lq-wq/luci-app-quickstart → package/luci-app-quickstart
# ------------------------------------------------------------
CONFIG_PACKAGE_quickstart=y
CONFIG_PACKAGE_luci-app-quickstart=y
CONFIG_PACKAGE_luci-i18n-quickstart-zh-cn=y

# ------------------------------------------------------------
# File Manager（Web 文件管理器）
# 使用 luci-app-filemanager，官方 luci feed 内置，纯 JS 实现，
# 无需 Go/Rust 工具链，稳定可靠。
# 原计划的 luci-app-filebrowser 依赖 Go 编译的 filebrowser 后端，
# 但 golang HOST 工具链在 GitHub Actions 上目前有编译 bug，
# 会导致该包被 defconfig 静默跳过（openwrt/packages #26446）。
# ------------------------------------------------------------
CONFIG_PACKAGE_luci-app-filemanager=y

# ------------------------------------------------------------
# 定时重启
# ------------------------------------------------------------
CONFIG_PACKAGE_luci-app-autoreboot=y
CONFIG_PACKAGE_luci-i18n-autoreboot-zh-cn=y

# ------------------------------------------------------------
# 明确禁用 Wi-Fi 驱动（无无线硬件）
# ------------------------------------------------------------
# CONFIG_PACKAGE_kmod-mt_wifi is not set
# CONFIG_PACKAGE_kmod-mt7915e is not set
# CONFIG_PACKAGE_kmod-mt7981-firmware is not set
# CONFIG_PACKAGE_mt7981-wo-firmware is not set
# CONFIG_PACKAGE_kmod-conninfra is not set
# CONFIG_PACKAGE_kmod-warp is not set
# CONFIG_PACKAGE_mtwifi-cfg is not set
# CONFIG_PACKAGE_luci-app-mtwifi-cfg is not set
# CONFIG_PACKAGE_datconf is not set
# CONFIG_PACKAGE_datconf-lua is not set
# CONFIG_PACKAGE_wifi-dats is not set
# CONFIG_PACKAGE_wireless-regdb is not set
# CONFIG_PACKAGE_wireless-tools is not set
# CONFIG_PACKAGE_iw is not set
# CONFIG_PACKAGE_iwinfo is not set

# ------------------------------------------------------------
# 明确禁用不需要的应用
# ------------------------------------------------------------
CONFIG_PACKAGE_luci-app-dockerman=n
CONFIG_PACKAGE_docker=n
CONFIG_PACKAGE_dockerd=n
CONFIG_PACKAGE_homeassistant=n

# SSR-Plus 完全禁用
# CONFIG_PACKAGE_luci-app-ssr-plus is not set

# PassWall 全部后端禁用
# CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Haproxy is not set
# CONFIG_PACKAGE_luci-app-passwall_INCLUDE_ShadowsocksR_Libev_Client is not set
# CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Shadowsocks_Libev_Client is not set
# CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Shadowsocks_Libev_Server is not set
# CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Shadowsocks_Rust_Client is not set
# CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Simple_Obfs is not set
# CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Trojan_Plus is not set
# CONFIG_PACKAGE_luci-app-passwall_INCLUDE_V2ray is not set
# CONFIG_PACKAGE_luci-app-passwall_INCLUDE_V2ray_Plugin is not set
# CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Xray is not set

# rclone
# CONFIG_PACKAGE_luci-app-rclone_INCLUDE_rclone-ng is not set
# CONFIG_PACKAGE_luci-app-rclone_INCLUDE_rclone-webui is not set
